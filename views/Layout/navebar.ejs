<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>RaidX – Kabaddi Platform</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        :root {
            --brand-red: #e63946;
            --brand-blue: #1d3557;
            --brand-accent: #457b9d;
            --brand-light: #f1faee;
        }

        body {
            padding-top: 64px;
            background-color: #f8f9fa;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        /* ── Navbar ── */
        .navbar {
            background: linear-gradient(135deg, var(--brand-blue) 0%, #2c4a6e 100%) !important;
            border-bottom: 3px solid var(--brand-red);
        }

        .navbar-brand {
            display: flex;
            align-items: center;
            gap: 8px;
            text-decoration: none;
        }

        .navbar-brand img {
            height: 42px;
            width: 42px;
            border-radius: 50%;
            object-fit: cover;
            border: 2px solid var(--brand-red);
        }

        .brand-raid { color: var(--brand-red); font-weight: 800; font-size: 1.5rem; letter-spacing: -1px; }
        .brand-x    { color: #fff;            font-weight: 900; font-size: 1.6rem; }

        .navbar-nav .nav-link {
            color: rgba(255,255,255,0.85) !important;
            font-weight: 500;
            padding: 0.5rem 1rem;
            border-radius: 6px;
            transition: background 0.2s, color 0.2s;
        }

        .navbar-nav .nav-link:hover,
        .navbar-nav .nav-link.active-link {
            background: rgba(255,255,255,0.15);
            color: #fff !important;
        }

        .navbar-toggler {
            border-color: rgba(255,255,255,0.4);
        }
        .navbar-toggler-icon {
            filter: invert(1);
        }

        /* Avatar button */
        .avatar-btn {
            width: 44px;
            height: 44px;
            border-radius: 50%;
            overflow: hidden;
            border: 2px solid var(--brand-red) !important;
            padding: 0;
            background: none;
            cursor: pointer;
            transition: transform 0.2s;
        }
        .avatar-btn:hover { transform: scale(1.08); }
        .avatar-btn img { width: 100%; height: 100%; object-fit: cover; }

        /* Profile dropdown */
        .profile-dropdown {
            min-width: 300px;
            border: none;
            border-radius: 12px;
            box-shadow: 0 8px 32px rgba(0,0,0,0.18);
            padding: 0;
            overflow: hidden;
        }

        .profile-dropdown .dropdown-header-bg {
            background: linear-gradient(135deg, var(--brand-blue), var(--brand-accent));
            padding: 20px;
            text-align: center;
            color: #fff;
        }

        .profile-dropdown .dropdown-header-bg img {
            width: 72px;
            height: 72px;
            border-radius: 50%;
            object-fit: cover;
            border: 3px solid #fff;
            margin-bottom: 8px;
        }

        .profile-dropdown .dropdown-body { padding: 12px 16px; }

        .profile-dropdown .info-row {
            display: flex;
            justify-content: space-between;
            padding: 5px 0;
            border-bottom: 1px solid #f0f0f0;
            font-size: 0.85rem;
        }
        .profile-dropdown .info-row:last-child { border-bottom: none; }
        .profile-dropdown .info-label { color: #6c757d; font-weight: 600; }

        /* Flash alerts */
        .flash-container { position: fixed; top: 70px; right: 16px; z-index: 1055; min-width: 280px; max-width: 380px; }

        /* ── Cards ── */
        .raidx-card {
            border: none;
            border-radius: 12px;
            box-shadow: 0 2px 12px rgba(0,0,0,0.08);
            transition: transform 0.2s, box-shadow 0.2s;
            overflow: hidden;
        }
        .raidx-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 8px 24px rgba(0,0,0,0.14);
        }

        /* ── Badges ── */
        .badge-live {
            background: var(--brand-red);
            color: #fff;
            font-size: 0.7rem;
            padding: 4px 8px;
            border-radius: 20px;
            animation: pulse 1.5s infinite;
        }
        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50%       { opacity: 0.6; }
        }

        /* ── Section headings ── */
        .section-title {
            font-weight: 700;
            color: var(--brand-blue);
            border-left: 4px solid var(--brand-red);
            padding-left: 12px;
            margin-bottom: 1.2rem;
        }

        /* ── Forms ── */
        .form-card {
            border: none;
            border-radius: 14px;
            box-shadow: 0 4px 24px rgba(0,0,0,0.10);
            overflow: hidden;
        }
        .form-card .card-header {
            background: linear-gradient(135deg, var(--brand-blue), var(--brand-accent));
            color: #fff;
            padding: 18px 24px;
            border: none;
        }
        .form-control:focus, .form-select:focus {
            border-color: var(--brand-accent);
            box-shadow: 0 0 0 0.2rem rgba(69,123,157,0.25);
        }

        /* ── Buttons ── */
        .btn-brand {
            background: linear-gradient(135deg, var(--brand-red), #c1121f);
            color: #fff;
            border: none;
            border-radius: 8px;
            font-weight: 600;
            transition: opacity 0.2s, transform 0.1s;
        }
        .btn-brand:hover { opacity: 0.9; transform: translateY(-1px); color: #fff; }

        .btn-brand-outline {
            border: 2px solid var(--brand-blue);
            color: var(--brand-blue);
            border-radius: 8px;
            font-weight: 600;
            background: transparent;
            transition: all 0.2s;
        }
        .btn-brand-outline:hover { background: var(--brand-blue); color: #fff; }

        /* ── Tables ── */
        .raidx-table thead {
            background: linear-gradient(135deg, var(--brand-blue), var(--brand-accent));
            color: #fff;
        }
        .raidx-table tbody tr:hover { background: rgba(69,123,157,0.07); }

        /* ── Footer ── */
        footer { margin-top: 60px !important; }

        /* ── Score display ── */
        .score-big {
            font-size: 3rem;
            font-weight: 800;
            line-height: 1;
        }

        /* ── Responsive tweaks ── */
        @media (max-width: 576px) {
            .profile-dropdown { min-width: 260px; }
            .score-big { font-size: 2rem; }
        }
    </style>
</head>
<body>
    <!-- ── Navbar ── -->
    <nav class="navbar navbar-expand-lg fixed-top shadow">
        <div class="container-fluid px-3">
            <!-- Brand -->
            <a class="navbar-brand" href="/">
                <img src="https://i.ytimg.com/vi/ExmCVRAsn3I/sddefault.jpg" alt="RaidX Logo">
                <span class="brand-raid">Raid</span><span class="brand-x">X</span>
            </a>

            <!-- Toggler -->
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <!-- Nav links -->
            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0 gap-1">
                    <li class="nav-item">
                        <a class="nav-link" href="/tournaments/view">
                            <i class="bi bi-trophy me-1"></i>Tournaments
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/tournament/form">
                            <i class="bi bi-plus-circle me-1"></i>New Tournament
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/live">
                            <i class="bi bi-broadcast me-1"></i>Live Matches
                        </a>
                    </li>
                </ul>

                <!-- Mobile: profile actions inside collapse -->
                <% if (currentUser) { %>
                <div class="d-lg-none border-top border-secondary mt-2 pt-2">
                    <div class="d-flex align-items-center gap-2 mb-2 px-1">
                        <img src="<%= currentUser.profile.url %>" alt="" style="width:36px;height:36px;border-radius:50%;object-fit:cover;border:2px solid var(--brand-red);">
                        <div>
                            <div class="text-white fw-semibold" style="font-size:.9rem;"><%= currentUser.fullName %></div>
                            <div class="text-white-50" style="font-size:.75rem;">@<%= currentUser.username %></div>
                        </div>
                    </div>
                    <a href="/user/<%= currentUser._id %>/detail" class="nav-link"><i class="bi bi-person me-1"></i>View Profile</a>
                    <a href="/user/<%= currentUser._id %>/edit" class="nav-link"><i class="bi bi-pencil me-1"></i>Edit Profile</a>
                    <a href="/logout" class="nav-link text-danger"><i class="bi bi-box-arrow-right me-1"></i>Log Out</a>
                </div>
                <% } %>
            </div>

            <!-- Desktop: avatar dropdown -->
            <% if (currentUser) { %>
            <div class="dropdown d-none d-lg-block ms-2">
                <button class="avatar-btn dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false" style="border:none;">
                    <img src="<%= currentUser.profile.url %>" alt="<%= currentUser.fullName %>">
                </button>
                <div class="dropdown-menu dropdown-menu-end profile-dropdown">
                    <div class="dropdown-header-bg">
                        <img src="<%= currentUser.profile.url %>" alt="<%= currentUser.fullName %>">
                        <div class="fw-bold fs-6"><%= currentUser.fullName %></div>
                        <div style="font-size:.8rem;opacity:.85;"><em><%= currentUser.prefferedPosition %></em></div>
                    </div>
                    <div class="dropdown-body">
                        <div class="info-row"><span class="info-label"><i class="bi bi-at me-1"></i>Username</span><span><%= currentUser.username %></span></div>
                        <div class="info-row"><span class="info-label"><i class="bi bi-envelope me-1"></i>Email</span><span><%= currentUser.email %></span></div>
                        <div class="info-row"><span class="info-label"><i class="bi bi-telephone me-1"></i>Phone</span><span><%= currentUser.phoneNumber %></span></div>
                        <div class="info-row"><span class="info-label"><i class="bi bi-geo-alt me-1"></i>Location</span><span><%= currentUser.city %>, <%= currentUser.state %></span></div>
                        <div class="info-row"><span class="info-label"><i class="bi bi-person me-1"></i>Gender / Age</span><span><%= currentUser.gender %>, <%= currentUser.age %> yrs</span></div>
                        <div class="d-grid gap-2 mt-3">
                            <a href="/user/<%= currentUser._id %>/detail" class="btn btn-sm btn-brand-outline"><i class="bi bi-person-lines-fill me-1"></i>View Profile</a>
                            <a href="/user/<%= currentUser._id %>/edit" class="btn btn-sm btn-outline-secondary"><i class="bi bi-pencil me-1"></i>Edit Profile</a>
                            <a href="/logout" class="btn btn-sm btn-outline-danger"><i class="bi bi-box-arrow-right me-1"></i>Log Out</a>
                        </div>
                        <hr class="my-2">
                        <% if (!currentUser.reviewId) { %>
                            <a href="/review/<%= currentUser._id %>" class="btn btn-brand w-100 btn-sm"><i class="bi bi-star me-1"></i>Write a Review</a>
                        <% } else { %>
                            <a href="/review/<%= currentUser.reviewId %>/edit" class="btn btn-brand w-100 btn-sm"><i class="bi bi-star-fill me-1"></i>Edit Review</a>
                        <% } %>
                    </div>
                </div>
            </div>
            <% } %>
        </div>
    </nav>

    <!-- ── Flash Messages ── -->
    <div class="flash-container">
        <% if (successMessage && successMessage.length) { %>
            <div class="alert alert-success alert-dismissible fade show shadow-sm rounded-3" role="alert">
                <i class="bi bi-check-circle-fill me-2"></i><%= successMessage %>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        <% } %>
        <% if (errorMessage && errorMessage.length) { %>
            <div class="alert alert-danger alert-dismissible fade show shadow-sm rounded-3" role="alert">
                <i class="bi bi-exclamation-triangle-fill me-2"></i><%= errorMessage %>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        <% } %>
    </div>

    <!-- ── Main Content ── -->
    <main>
        <%- body -%>
    </main>

    <%- include("./footer.ejs") %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
    <script>
        // Auto-dismiss flash messages after 4 s
        document.querySelectorAll('.flash-container .alert').forEach(el => {
            setTimeout(() => {
                const bsAlert = bootstrap.Alert.getOrCreateInstance(el);
                bsAlert.close();
            }, 4000);
        });

        // Highlight active nav link
        const currentPath = '<%= currentPath %>';
        document.querySelectorAll('.navbar-nav .nav-link').forEach(link => {
            if (link.getAttribute('href') === currentPath) link.classList.add('active-link');
        });
    </script>
</body>
</html>
