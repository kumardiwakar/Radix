<% layout('./Layout/navebar') -%>

<div class="d-flex align-items-center justify-content-center" style="min-height:calc(100vh - 120px);">
    <div class="text-center px-3">
        <div class="mb-4">
            <div class="rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width:80px;height:80px;background:linear-gradient(135deg,#1d3557,#457b9d);">
                <i class="bi bi-shield-check-fill text-white" style="font-size:2rem;"></i>
            </div>
        </div>
        <h1 class="fw-bold mb-2" style="color:#1d3557;">You're Logged In!</h1>
        <p class="text-muted mb-4">Welcome to RaidX. Ready to explore tournaments and matches?</p>
        <div class="d-flex gap-3 justify-content-center flex-wrap">
            <a href="/tournaments/view" class="btn btn-brand px-4 py-2">
                <i class="bi bi-trophy me-2"></i>Browse Tournaments
            </a>
            <a href="/live" class="btn btn-outline-danger px-4 py-2">
                <i class="bi bi-broadcast me-2"></i>Live Matches
            </a>
        </div>
    </div>
</div>
