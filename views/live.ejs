<% layout('./Layout/navebar') -%>

<div class="container py-4">
    <!-- Header -->
    <div class="d-flex align-items-center gap-3 mb-4">
        <div class="rounded-circle d-flex align-items-center justify-content-center" style="width:48px;height:48px;background:rgba(230,57,70,.12);">
            <i class="bi bi-broadcast-pin fs-4" style="color:#e63946;"></i>
        </div>
        <div>
            <h2 class="fw-bold mb-0" style="color:#1d3557;">Live Action</h2>
            <p class="text-muted mb-0" style="font-size:.85rem;">Matches happening right now</p>
        </div>
    </div>

    <%
        const liveMatches = matches.filter(m => m.winner === 'Panding');
    %>

    <% if (liveMatches.length > 0) { %>
    <div class="row g-4">
        <% for (match of liveMatches) { %>
        <div class="col-md-6 col-lg-4">
            <a href="/match/<%= match._id %>/detail/live" class="raidx-card card text-decoration-none h-100 position-relative">
                <div style="height:4px;background:linear-gradient(90deg,#e63946,#c1121f);"></div>
                <div class="card-body p-4">
                    <!-- Tournament name -->
                    <h6 class="fw-bold mb-1" style="color:#1d3557;"><%= match.tournamentId.tournamentName %></h6>
                    <p class="text-muted mb-3" style="font-size:.8rem;">
                        <i class="bi bi-geo-alt me-1"></i><%= match.tournamentId.location %>
                    </p>

                    <!-- Match type pill -->
                    <span class="badge bg-light text-dark border mb-3" style="font-size:.78rem;"><%= match.matchType %></span>

                    <!-- Scoreboard -->
                    <div class="d-flex justify-content-between align-items-center p-2 rounded mb-2" style="background:#f8f9fa;">
                        <span class="fw-semibold"><%= match.teamA.teamName %></span>
                        <span class="fw-bold fs-5" style="color:#1d3557;"><%= match.totalPointA %></span>
                    </div>
                    <div class="text-center text-muted fw-bold" style="font-size:.75rem;letter-spacing:1px;">VS</div>
                    <div class="d-flex justify-content-between align-items-center p-2 rounded mt-2" style="background:#f8f9fa;">
                        <span class="fw-semibold"><%= match.teamB.teamName %></span>
                        <span class="fw-bold fs-5" style="color:#1d3557;"><%= match.totalPointB %></span>
                    </div>
                </div>

                <!-- Live badge -->
                <div class="position-absolute top-0 end-0 m-3">
                    <span class="badge-live rounded-pill" style="font-size:.7rem;padding:5px 10px;">
                        <i class="bi bi-broadcast me-1"></i>Live
                    </span>
                </div>
            </a>
        </div>
        <% } %>
    </div>
    <% } else { %>
    <div class="text-center py-5">
        <div class="mb-3">
            <i class="bi bi-broadcast" style="font-size:4rem;color:#dee2e6;"></i>
        </div>
        <h5 class="text-muted">No live matches right now</h5>
        <p class="text-muted" style="font-size:.9rem;">Check back soon or browse upcoming tournaments.</p>
        <a href="/tournaments/view" class="btn btn-brand mt-2">
            <i class="bi bi-trophy me-1"></i>View Tournaments
        </a>
    </div>
    <% } %>
</div>
