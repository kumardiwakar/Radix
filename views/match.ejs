<% layout('./Layout/navebar') -%>

<div class="container py-5" style="max-width:560px;">
    <div class="form-card card">
        <div class="card-header">
            <h4 class="mb-0 fw-bold"><i class="bi bi-plus-circle-fill me-2"></i>Schedule New Match</h4>
        </div>
        <div class="card-body p-4">
            <form method="post" action="/match/<%= id %>">
                <div class="mb-3">
                    <label for="teamA" class="form-label fw-semibold">Team A</label>
                    <input type="text" id="teamA" name="teamA" class="form-control" placeholder="Enter Team A name" required>
                </div>
                <div class="mb-3">
                    <label for="teamB" class="form-label fw-semibold">Team B</label>
                    <input type="text" id="teamB" name="teamB" class="form-control" placeholder="Enter Team B name" required>
                </div>
                <div class="mb-4">
                    <label for="matchType" class="form-label fw-semibold">Match Type</label>
                    <input type="text" id="matchType" name="matchType" class="form-control" placeholder="e.g. Semi-Final, Final, Group Stage" required>
                </div>
                <button type="submit" class="btn btn-brand w-100 py-2">
                    <i class="bi bi-check-circle me-2"></i>Add Match
                </button>
            </form>
        </div>
    </div>
</div>
