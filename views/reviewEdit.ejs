<% layout('./Layout/navebar') -%>

<div class="container py-5" style="max-width:560px;">
    <div class="form-card card">
        <div class="card-header">
            <h4 class="mb-0 fw-bold"><i class="bi bi-star-half me-2"></i>Edit Your Review</h4>
        </div>
        <div class="card-body p-4">
            <form method="post" action="/review/<%= oldReview._id %>/edit?_method=PATCH">
                <div class="mb-4">
                    <label for="review" class="form-label fw-semibold">Your Review</label>
                    <textarea id="review" name="review" class="form-control" rows="5" required><%= oldReview.review %></textarea>
                </div>
                <button type="submit" class="btn btn-brand w-100 py-2">
                    <i class="bi bi-save me-2"></i>Update Review
                </button>
            </form>
        </div>
    </div>
</div>
