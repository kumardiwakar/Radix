<% layout('./Layout/navebar') -%>

<div class="container py-5" style="max-width:520px;">
    <div class="form-card card">
        <div class="card-header">
            <h4 class="mb-0 fw-bold"><i class="bi bi-people-fill me-2"></i>Add New Team</h4>
        </div>
        <div class="card-body p-4">
            <form method="post" action="/team/<%= id %>/add">
                <div class="mb-3">
                    <label for="teamName" class="form-label fw-semibold">Team Name</label>
                    <input type="text" class="form-control" id="teamName" name="teamName" placeholder="Enter team name" required>
                </div>
                <div class="mb-4">
                    <label for="captainUsername" class="form-label fw-semibold">Captain's Username</label>
                    <input type="text" class="form-control" id="captainUsername" name="captainUsername" placeholder="Enter captain's username" required>
                </div>
                <button type="submit" class="btn btn-brand w-100 py-2">
                    <i class="bi bi-check-circle me-2"></i>Add Team
                </button>
            </form>
        </div>
    </div>
</div>
