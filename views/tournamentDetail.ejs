<% layout('./Layout/navebar') -%>

<div class="container py-4">

    <!-- ── Hero Banner ── -->
    <div class="rounded-4 overflow-hidden mb-4 position-relative" style="background:linear-gradient(135deg,#1d3557,#2c4a6e);min-height:180px;">
        <div class="position-absolute inset-0 w-100 h-100" style="background:url('https://www.shutterstock.com/image-vector/premium-editable-vector-file-kabaddi-260nw-2286738699.jpg') center/cover no-repeat;opacity:.12;"></div>
        <div class="position-relative p-4 p-md-5 text-white">
            <div class="d-flex flex-wrap align-items-start justify-content-between gap-3">
                <div>
                    <h1 class="fw-bold mb-1" style="font-size:clamp(1.5rem,4vw,2.5rem);"><%= tournament.tournamentName %></h1>
                    <p class="mb-1 opacity-75"><i class="bi bi-geo-alt-fill me-1" style="color:#e63946;"></i><%= tournament.location %></p>
                    <p class="mb-0 opacity-75">
                        <i class="bi bi-calendar-range me-1" style="color:#a8dadc;"></i>
                        <%=`${new Date(tournament.startDate).getDate()}/${new Date(tournament.startDate).getMonth()+1}/${new Date(tournament.startDate).getFullYear()}`%>
                        &nbsp;–&nbsp;
                        <%=`${new Date(tournament.endDate).getDate()}/${new Date(tournament.endDate).getMonth()+1}/${new Date(tournament.endDate).getFullYear()}`%>
                    </p>
                </div>
                <% if (userId && String(userId) === String(tournament.organiserId._id)) { %>
                <div class="d-flex gap-2 flex-wrap">
                    <% if (new Date(tournament.endDate) >= new Date()) { %>
                    <a href="/team/<%= tournament._id %>/add" class="btn btn-sm btn-light fw-semibold">
                        <i class="bi bi-people-fill me-1"></i>Add Team
                    </a>
                    <% } %>
                    <% if (new Date(tournament.startDate) <= new Date() && new Date(tournament.endDate) >= new Date()) { %>
                    <a href="/match/<%= tournament._id %>" class="btn btn-sm btn-brand">
                        <i class="bi bi-plus-circle me-1"></i>New Match
                    </a>
                    <% } %>
                </div>
                <% } %>
            </div>
        </div>
    </div>

    <!-- ── Teams ── -->
    <h3 class="section-title"><i class="bi bi-people-fill me-2"></i>Teams</h3>
    <div class="row g-3 mb-5">
        <% for (team of tournament.team) { %>
        <div class="col-md-6 col-lg-4">
            <div class="raidx-card card h-100">
                <div style="height:3px;background:linear-gradient(90deg,#e63946,#457b9d);"></div>
                <div class="card-body p-3">
                    <h5 class="fw-bold text-center mb-1" style="color:#1d3557;"><%= team.teamName %></h5>
                    <p class="text-center text-muted mb-3" style="font-size:.85rem;">
                        <i class="bi bi-star-fill me-1" style="color:#e63946;"></i>Captain: <strong><%= team.captainId.fullName %></strong>
                    </p>

                    <% if (userId && String(userId) === String(tournament.organiserId._id)) { %>
                    <div class="d-flex justify-content-between text-muted mb-3" style="font-size:.82rem;">
                        <span><i class="bi bi-telephone me-1"></i><%= team.captainId.phoneNumber %></span>
                        <span><i class="bi bi-person-check me-1"></i><%= team.players.length %> players</span>
                    </div>

                    <% if (new Date() <= new Date(tournament.endDate) && team.players.length < 12) { %>
                    <div class="dropdown mb-3">
                        <button type="button" class="btn btn-outline-primary btn-sm w-100 dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false" data-bs-auto-close="outside">
                            <i class="bi bi-person-plus me-1"></i>Add Player
                        </button>
                        <form class="dropdown-menu p-3 shadow" style="min-width:240px;" method="POST" action="/tournament/<%= tournament._id %>/team/<%= team._id %>/player/add">
                            <label class="form-label fw-semibold" style="font-size:.85rem;">Player's Username</label>
                            <input type="text" class="form-control form-control-sm mb-2" placeholder="Enter username" name="userName">
                            <button type="submit" class="btn btn-brand btn-sm w-100">Add</button>
                        </form>
                    </div>
                    <% } %>
                    <% } %>

                    <a href="/team/<%= team._id %>/detail" class="btn btn-brand btn-sm w-100">
                        <i class="bi bi-eye me-1"></i>Team Details
                    </a>
                </div>
            </div>
        </div>
        <% } %>
    </div>

    <!-- ── Live Matches ── -->
    <% const liveMatches = tournament.match.filter(m => m.winner === 'Panding'); %>
    <% if (liveMatches.length > 0) { %>
    <h3 class="section-title"><i class="bi bi-broadcast me-2" style="color:#e63946;"></i>Live Matches</h3>
    <div class="row g-3 mb-5">
        <% for (match of liveMatches) { %>
        <div class="col-md-6 col-lg-4">
            <a href="/match/<%= match._id %>/detail/live" class="raidx-card card text-decoration-none h-100 position-relative">
                <div style="height:3px;background:linear-gradient(90deg,#e63946,#c1121f);"></div>
                <div class="card-body p-3">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <h6 class="fw-bold mb-0" style="color:#1d3557;"><%= tournament.tournamentName %></h6>
                        <span class="badge-live rounded-pill" style="font-size:.68rem;padding:4px 8px;"><i class="bi bi-broadcast me-1"></i>Live</span>
                    </div>
                    <p class="text-muted mb-1" style="font-size:.8rem;">
                        <i class="bi bi-geo-alt me-1"></i><%= tournament.location %>
                        &nbsp;·&nbsp;
                        <%=`${new Date(match.createdAt).getDate()}-${new Date(match.createdAt).getMonth()+1}-${new Date(match.createdAt).getFullYear()}`%>
                    </p>
                    <span class="badge bg-light text-dark border mb-3" style="font-size:.75rem;"><%= match.matchType %></span>
                    <div class="d-flex justify-content-between align-items-center mb-1">
                        <span class="fw-semibold" style="font-size:.9rem;"><%= match.teamA.teamName %></span>
                        <span class="badge bg-danger"><%= match.totalPointA %></span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="fw-semibold" style="font-size:.9rem;"><%= match.teamB.teamName %></span>
                        <span class="badge bg-danger"><%= match.totalPointB %></span>
                    </div>
                    <hr class="my-2">
                    <p class="text-center fw-bold text-danger mb-0" style="font-size:.85rem;"><i class="bi bi-hourglass-split me-1"></i>In Progress</p>
                </div>
            </a>
        </div>
        <% } %>
    </div>
    <% } %>

    <!-- ── Past Matches ── -->
    <% const pastMatches = tournament.match.filter(m => m.winner !== 'Panding'); %>
    <% if (pastMatches.length > 0) { %>
    <h3 class="section-title"><i class="bi bi-clock-history me-2"></i>Past Matches</h3>
    <div class="row g-3">
        <% for (match of pastMatches) { %>
        <div class="col-md-6 col-lg-4">
            <a href="/match/<%= match._id %>/detail/live" class="raidx-card card text-decoration-none h-100 position-relative">
                <div style="height:3px;background:linear-gradient(90deg,#6c757d,#adb5bd);"></div>
                <div class="card-body p-3">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <h6 class="fw-bold mb-0" style="color:#1d3557;"><%= tournament.tournamentName %></h6>
                        <span class="badge bg-success rounded-pill" style="font-size:.68rem;">Past</span>
                    </div>
                    <p class="text-muted mb-1" style="font-size:.8rem;">
                        <i class="bi bi-geo-alt me-1"></i><%= tournament.location %>
                        &nbsp;·&nbsp;
                        <%=`${new Date(match.createdAt).getDate()}-${new Date(match.createdAt).getMonth()+1}-${new Date(match.createdAt).getFullYear()}`%>
                    </p>
                    <span class="badge bg-light text-dark border mb-3" style="font-size:.75rem;"><%= match.matchType %></span>
                    <div class="d-flex justify-content-between align-items-center mb-1">
                        <span class="fw-semibold" style="font-size:.9rem;"><%= match.teamA.teamName %></span>
                        <span class="badge bg-secondary"><%= match.totalPointA %></span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="fw-semibold" style="font-size:.9rem;"><%= match.teamB.teamName %></span>
                        <span class="badge bg-secondary"><%= match.totalPointB %></span>
                    </div>
                    <hr class="my-2">
                    <p class="text-center fw-bold text-success mb-0" style="font-size:.85rem;"><i class="bi bi-trophy me-1"></i><%= match.winner %></p>
                </div>
            </a>
        </div>
        <% } %>
    </div>
    <% } %>

    <% if (tournament.match.length === 0) { %>
    <div class="text-center py-4 text-muted">
        <i class="bi bi-calendar-x" style="font-size:3rem;color:#dee2e6;"></i>
        <p class="mt-2">No matches scheduled yet.</p>
    </div>
    <% } %>

</div>

<style>
    /* Inline live match cards for this page */
    .live-match-card {
        border: none;
        border-radius: 12px;
        box-shadow: 0 2px 12px rgba(0,0,0,.08);
        transition: transform .2s, box-shadow .2s;
        overflow: hidden;
        text-decoration: none;
        display: block;
        color: inherit;
    }
    .live-match-card:hover { transform: translateY(-4px); box-shadow: 0 8px 24px rgba(0,0,0,.14); }
</style>
