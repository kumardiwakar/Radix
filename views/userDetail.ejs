<% layout('./Layout/navebar') -%>

<div class="container py-4">

    <!-- ── My Matches ── -->
    <h3 class="section-title mb-4"><i class="bi bi-controller me-2"></i>My Matches</h3>

    <% if (userMatches && userMatches.matchPlayedId && userMatches.matchPlayedId.length > 0) { %>
    <div class="row g-3 mb-5">
        <% for (match of userMatches.matchPlayedId) { %>
        <div class="col-md-6 col-lg-4">
            <a href="/match/<%= match._id %>/detail/live" class="raidx-card card text-decoration-none h-100 position-relative">
                <div style="height:3px;background:<%= match.winner === 'Panding' ? 'linear-gradient(90deg,#e63946,#c1121f)' : 'linear-gradient(90deg,#28a745,#20c997)' %>;"></div>
                <div class="card-body p-3">
                    <h6 class="fw-bold mb-1" style="color:#1d3557;"><%= match.tournamentId.tournamentName %></h6>
                    <p class="text-muted mb-2" style="font-size:.8rem;">
                        <i class="bi bi-geo-alt me-1"></i><%= match.tournamentId.location %>
                    </p>
                    <span class="badge bg-light text-dark border mb-3" style="font-size:.75rem;"><%= match.matchType %></span>

                    <div class="d-flex justify-content-between align-items-center mb-1">
                        <span class="fw-semibold" style="font-size:.9rem;"><%= match.teamA.teamName %></span>
                        <span class="badge bg-secondary"><%= match.totalPointA %></span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="fw-semibold" style="font-size:.9rem;"><%= match.teamB.teamName %></span>
                        <span class="badge bg-secondary"><%= match.totalPointB %></span>
                    </div>
                    <hr class="my-2">
                    <p class="text-center fw-bold mb-0" style="font-size:.85rem;color:<%= match.winner === 'Panding' ? '#e63946' : '#28a745' %>;">
                        <% if (match.winner === 'Panding') { %>
                            <i class="bi bi-broadcast me-1"></i>In Progress
                        <% } else { %>
                            <i class="bi bi-trophy me-1"></i><%= match.winner %>
                        <% } %>
                    </p>
                </div>
                <div class="position-absolute top-0 end-0 m-2">
                    <% if (match.winner === 'Panding') { %>
                        <span class="badge-live rounded-pill" style="font-size:.65rem;padding:3px 8px;"><i class="bi bi-broadcast me-1"></i>Live</span>
                    <% } else { %>
                        <span class="badge bg-success rounded-pill" style="font-size:.65rem;padding:3px 8px;">Past</span>
                    <% } %>
                </div>
            </a>
        </div>
        <% } %>
    </div>
    <% } else { %>
    <div class="text-center py-4 mb-5">
        <i class="bi bi-controller" style="font-size:3rem;color:#dee2e6;"></i>
        <p class="text-muted mt-2">No matches played yet.</p>
    </div>
    <% } %>

    <!-- ── My Tournaments ── -->
    <h3 class="section-title mb-4"><i class="bi bi-trophy-fill me-2"></i>My Tournaments</h3>

    <% if (userMatches && userMatches.TournamentId && userMatches.TournamentId.length > 0) { %>
    <div class="row g-3">
        <% for (tournament of userMatches.TournamentId) { %>
        <% if (String(tournament.organiserId) === String(currentUser._id)) { %>
        <%
            const end   = new Date(tournament.endDate);
            const start = new Date(tournament.startDate);
            const now   = new Date();
            const isLive = start <= now && end >= now;
        %>
        <div class="col-md-6 col-lg-4">
            <div class="raidx-card card h-100 position-relative">
                <div style="height:3px;background:<%= isLive ? 'linear-gradient(90deg,#e63946,#c1121f)' : 'linear-gradient(90deg,#457b9d,#1d3557)' %>;"></div>
                <div class="card-body p-3">
                    <h6 class="fw-bold mb-1" style="color:#1d3557;"><%= tournament.tournamentName %></h6>
                    <p class="text-muted mb-2" style="font-size:.82rem;"><%= tournament.description %></p>
                    <div class="d-flex flex-column gap-1 mb-3" style="font-size:.82rem;">
                        <div><i class="bi bi-geo-alt me-1" style="color:#e63946;"></i><%= tournament.location %></div>
                        <div><i class="bi bi-calendar me-1" style="color:#457b9d;"></i>
                            <%=`${new Date(tournament.startDate).getDate()}/${new Date(tournament.startDate).getMonth()+1}/${new Date(tournament.startDate).getFullYear()}`%>
                            →
                            <%=`${new Date(tournament.endDate).getDate()}/${new Date(tournament.endDate).getMonth()+1}/${new Date(tournament.endDate).getFullYear()}`%>
                        </div>
                    </div>
                    <a href="/tournament/<%= tournament._id %>/detail/view" class="btn btn-brand btn-sm w-100">
                        <i class="bi bi-eye me-1"></i>View Details
                    </a>
                </div>
                <div class="position-absolute top-0 end-0 m-2">
                    <% if (isLive) { %>
                        <span class="badge-live rounded-pill" style="font-size:.65rem;padding:3px 8px;"><i class="bi bi-broadcast me-1"></i>Live</span>
                    <% } else { %>
                        <span class="badge rounded-pill" style="background:#457b9d;color:#fff;font-size:.65rem;padding:3px 8px;">Upcoming</span>
                    <% } %>
                </div>
            </div>
        </div>
        <% } %>
        <% } %>
    </div>
    <% } else { %>
    <div class="text-center py-4">
        <i class="bi bi-trophy" style="font-size:3rem;color:#dee2e6;"></i>
        <p class="text-muted mt-2">No tournaments organised yet.</p>
        <a href="/tournament/form" class="btn btn-brand btn-sm mt-1">
            <i class="bi bi-plus-lg me-1"></i>Create Tournament
        </a>
    </div>
    <% } %>

</div>
